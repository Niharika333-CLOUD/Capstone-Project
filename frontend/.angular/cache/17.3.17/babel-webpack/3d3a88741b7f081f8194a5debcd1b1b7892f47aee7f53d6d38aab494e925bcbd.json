{"ast":null,"code":"export {};","map":{"version":3,"names":[],"sources":["C:\\Users\\NiharikaNJain\\Documents\\GitHub\\Capstone-Project\\frontend\\src\\app\\features\\wishlist\\wishlist.component.ts"],"sourcesContent":["import { Component, OnInit, inject } from '@angular/core';\r\nimport { CommonModule } from '@angular/common';\r\nimport { RouterLink } from '@angular/router';\r\nimport { WishlistService } from '../../core/services/wishlist.service';\r\nimport { CartService } from '../../core/services/cart.service';\r\nimport { Product } from '../../core/models/product.model';\r\n\r\n@Component({\r\n  selector: 'app-wishlist',\r\n  standalone: true,\r\n  imports: [CommonModule, RouterLink],\r\n  template: `\r\n    <div class=\"wishlist-page\">\r\n      <div class=\"container\">\r\n        <div class=\"page-header\">\r\n          <h1 class=\"page-title\">My Wishlist</h1>\r\n          <p class=\"page-subtitle\">{{ wishlistItems.length }} item(s) in your wishlist</p>\r\n        </div>\r\n\r\n        <!-- Loading State -->\r\n        <div *ngIf=\"loading\" class=\"loading-container\">\r\n          <div class=\"spinner\"></div>\r\n          <p>Loading your wishlist...</p>\r\n        </div>\r\n\r\n        <!-- Error State -->\r\n        <div *ngIf=\"error\" class=\"error-message\">\r\n          <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\r\n            <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\r\n            <line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"></line>\r\n            <line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"></line>\r\n          </svg>\r\n          <p>{{ error }}</p>\r\n          <button class=\"btn btn-primary\" (click)=\"loadWishlist()\">Try Again</button>\r\n        </div>\r\n\r\n        <!-- Wishlist Grid -->\r\n        <div *ngIf=\"!loading && !error && wishlistItems.length > 0\" class=\"wishlist-grid\">\r\n          <div class=\"wishlist-card\" *ngFor=\"let product of wishlistItems; trackBy: trackByProductId\">\r\n            <!-- Product Image -->\r\n            <div class=\"product-image-container\">\r\n              <img \r\n"],"mappings":"AA0CA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}