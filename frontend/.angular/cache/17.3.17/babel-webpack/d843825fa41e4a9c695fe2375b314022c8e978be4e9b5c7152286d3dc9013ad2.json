{"ast":null,"code":"export {};","map":{"version":3,"names":[],"sources":["C:\\Users\\NiharikaNJain\\Documents\\GitHub\\Capstone-Project\\frontend\\src\\app\\features\\wishlist\\wishlist.component.ts"],"sourcesContent":["import { Component, OnInit, inject } from '@angular/core';\r\nimport { CommonModule } from '@angular/common';\r\nimport { RouterLink } from '@angular/router';\r\nimport { WishlistService } from '../../core/services/wishlist.service';\r\nimport { CartService } from '../../core/services/cart.service';\r\nimport { Product } from '../../core/models/product.model';\r\n\r\n@Component({\r\n  selector: 'app-wishlist',\r\n  standalone: true,\r\n  imports: [CommonModule, RouterLink],\r\n  template: `\r\n    <div class=\"wishlist-page\">\r\n      <div class=\"container\">\r\n        <div class=\"page-header\">\r\n          <h1 class=\"page-title\">My Wishlist</h1>\r\n          <p class=\"page-subtitle\">{{ wishlistItems.length }} item(s) in your wishlist</p>\r\n        </div>\r\n\r\n        <!-- Loading State -->\r\n        <div *ngIf=\"loading\" class=\"loading-container\">\r\n          <div class=\"spinner\"></div>\r\n          <p>Loading your wishlist...</p>\r\n        </div>\r\n\r\n        <!-- Error State -->\r\n        <div *ngIf=\"error\" class=\"error-message\">\r\n          <svg width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\r\n            <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\r\n            <line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\"></line>\r\n            <line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\"></line>\r\n          </svg>\r\n          <p>{{ error }}</p>\r\n          <button class=\"btn btn-primary\" (click)=\"loadWishlist()\">Try Again</button>\r\n        </div>\r\n\r\n        <!-- Wishlist Grid -->\r\n        <div *ngIf=\"!loading && !error && wishlistItems.length > 0\" class=\"wishlist-grid\">\r\n          <div class=\"wishlist-card\" *ngFor=\"let product of wishlistItems; trackBy: trackByProductId\">\r\n            <!-- Product Image -->\r\n            <div class=\"product-image-container\">\r\n              <img \r\n                [src]=\"product.images?.[0]?.url || product.coverImage || 'assets/placeholder-book.jpg'\" \r\n                [alt]=\"product.title\"\r\n                class=\"product-image\"\r\n                [routerLink]=\"['/products', product._id]\">\r\n              \r\n              <!-- Remove from Wishlist Button -->\r\n              <button \r\n                class=\"remove-wishlist-btn\"\r\n                (click)=\"removeFromWishlist(product)\"\r\n                title=\"Remove from wishlist\">\r\n                <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"currentColor\" stroke=\"currentColor\" stroke-width=\"2\">\r\n                  <path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\"></path>\r\n                </svg>\r\n              </button>\r\n\r\n              <!-- Stock Badge -->\r\n              <div class=\"stock-badge\" *ngIf=\"product.stock <= 0\">\r\n                Out of Stock\r\n              </div>\r\n              <div class=\"stock-badge low-stock\" *ngIf=\"product.stock > 0 && product.stock < 5\">\r\n                Only {{ product.stock }} left\r\n              </div>\r\n            </div>\r\n\r\n            <!-- Product Details -->\r\n            <div class=\"product-details\">\r\n              <h3 class=\"product-title\" [routerLink]=\"['/products', product._id]\">\r\n                {{ product.title }}\r\n              </h3>\r\n              <p class=\"product-author\">by {{ product.author }}</p>\r\n\r\n              <!-- Rating -->\r\n              <div class=\"product-rating\" *ngIf=\"product.averageRating\">\r\n                <div class=\"stars\">\r\n                  <span class=\"star\" *ngFor=\"let star of [1,2,3,4,5]\" \r\n                        [class.filled]=\"star <= product.averageRating\">★</span>\r\n                </div>\r\n                <span class=\"rating-count\">({{ product.reviewCount || 0 }})</span>\r\n              </div>\r\n\r\n              <!-- Price -->\r\n              <div class=\"product-price\">\r\n                <span class=\"current-price\">₹{{ product.price.toFixed(2) }}</span>\r\n                <span class=\"original-price\" *ngIf=\"product.originalPrice && product.originalPrice > product.price\">\r\n                  ₹{{ product.originalPrice.toFixed(2) }}\r\n"],"mappings":"AAuFA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}