{"ast":null,"code":"export {};","map":{"version":3,"names":[],"sources":["C:\\Users\\NiharikaNJain\\Documents\\GitHub\\Capstone-Project\\frontend\\src\\app\\features\\orders\\order-list\\order-list.component.ts"],"sourcesContent":["import { Component, OnInit, inject } from '@angular/core';\r\nimport { CommonModule } from '@angular/common';\r\nimport { RouterLink } from '@angular/router';\r\nimport { OrderService } from '../../../core/services/order.service';\r\nimport { Order } from '../../../core/models/order.model';\r\n\r\n@Component({\r\n  selector: 'app-order-list',\r\n  standalone: true,\r\n  imports: [CommonModule, RouterLink],\r\n  template: `\r\n    <div class=\"orders-page\">\r\n      <div class=\"container\">\r\n        <div class=\"page-header\">\r\n          <h1 class=\"page-title\">My Orders</h1>\r\n          <p class=\"page-subtitle\">Track and manage your orders</p>\r\n        </div>\r\n\r\n        <!-- Filter Tabs -->\r\n        <div class=\"filter-tabs\">\r\n          <button \r\n            class=\"filter-tab\"\r\n            [class.active]=\"selectedFilter === 'all'\"\r\n            (click)=\"filterOrders('all')\">\r\n            All Orders\r\n            <span class=\"count\" *ngIf=\"orders.length > 0\">{{ orders.length }}</span>\r\n          </button>\r\n          <button \r\n            class=\"filter-tab\"\r\n            [class.active]=\"selectedFilter === 'pending'\"\r\n            (click)=\"filterOrders('pending')\">\r\n            Processing\r\n            <span class=\"count\">{{ getOrderCountByStatus('pending') }}</span>\r\n          </button>\r\n          <button \r\n            class=\"filter-tab\"\r\n            [class.active]=\"selectedFilter === 'shipped'\"\r\n            (click)=\"filterOrders('shipped')\">\r\n            Shipped\r\n            <span class=\"count\">{{ getOrderCountByStatus('shipped') }}</span>\r\n          </button>\r\n          <button \r\n            class=\"filter-tab\"\r\n            [class.active]=\"selectedFilter === 'delivered'\"\r\n            (click)=\"filterOrders('delivered')\">\r\n            Delivered\r\n            <span class=\"count\">{{ getOrderCountByStatus('delivered') }}</span>\r\n          </button>\r\n          <button \r\n            class=\"filter-tab\"\r\n            [class.active]=\"selectedFilter === 'cancelled'\"\r\n            (click)=\"filterOrders('cancelled')\">\r\n            Cancelled\r\n            <span class=\"count\">{{ getOrderCountByStatus('cancelled') }}</span>\r\n          </button>\r\n        </div>\r\n\r\n        <!-- Loading State -->\r\n        <div *ngIf=\"loading\" class=\"loading-container\">\r\n          <div class=\"spinner\"></div>\r\n          <p>Loading your orders...</p>\r\n        </div>\r\n\r\n        <!-- Error State -->\r\n        <div *ngIf=\"error\" class=\"error-message\">\r\n"],"mappings":"AAiEA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}